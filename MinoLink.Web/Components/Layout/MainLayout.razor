@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.Extensions.DependencyInjection
@using MinoLink.Core.Interfaces
@using MinoLink.Core.Models
@using MinoLink.Core.Services
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JS
@inject IAppVersionProvider AppVersionProvider
@inject IAppUpdateService AppUpdateService
@inject IAppUpdatePackageService AppUpdatePackageService

<div class="layout">
    <nav class="topnav">
        <div class="nav-left">
            <div class="nav-brand">Mino<span class="dot">Link</span></div>
            <div class="nav-links">
                <NavLink href="" Match="NavLinkMatch.All">概览</NavLink>
                <NavLink href="config">配置</NavLink>
                <NavLink href="sessions">会话管理</NavLink>
                <NavLink href="guide">使用指南</NavLink>
            </div>
        </div>
        <div class="nav-right">
            <span class="nav-dot"></span>
            <span class="nav-status-text">运行中</span>
            <span class="nav-version" title="当前版本">@AppVersionProvider.Version</span>
            <button class="nav-update-link" type="button" title="检查更新" @onclick="OpenUpdateModal">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1v6m0 0l3-3m-3 3L5 4M3 9v3a2 2 0 002 2h6a2 2 0 002-2V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>检查更新</span>
            </button>

            @if (_autoStartService is not null)
            {
                <button class="nav-icon-btn @(_autoStart ? "active" : "")"
                        title="@(_autoStart ? "开机自启：已开启" : "开机自启：已关闭")"
                        @onclick="ToggleAutoStart">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M8 1.75v4.75" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M11.9 3.15a5.25 5.25 0 11-7.8 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>自启</span>
                </button>
            }

            <button class="nav-icon-btn" title="切换主题" @onclick="ToggleTheme">
                @if (_isDark)
                {
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 1v2m0 10v2m-5-7H1m14 0h-2m-1.05-4.95L10.54 5.46M5.46 10.54l-1.41 1.41m0-7.9l1.41 1.41m5.08 5.08l1.41 1.41" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M14 9.5A6.5 6.5 0 016.5 2 5.5 5.5 0 1014 9.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                }
            </button>
        </div>
    </nav>

    <main class="main-content">
        @Body
    </main>
</div>

@if (_showUpdateModal)
{
    <div class="update-modal-backdrop" @onclick="CloseUpdateModal">
        <div class="update-modal-card" @onclick:stopPropagation="true">
            <div class="update-modal-header">
                <div>
                    <h3>版本与更新</h3>
                    <p>当前版本 @AppVersionProvider.Version</p>
                </div>
                <button class="update-modal-close" type="button" title="关闭" @onclick="CloseUpdateModal">×</button>
            </div>

            <div class="update-modal-body">
                <div class="update-meta-row">
                    <div class="update-meta-pill">
                        <span>当前版本</span>
                        <strong>@AppVersionProvider.Version</strong>
                    </div>
                    <div class="update-meta-pill">
                        <span>更新源</span>
                        <strong>GitHub Release</strong>
                    </div>
                    @if (_updateResult?.LatestRelease is not null)
                    {
                        <div class="update-meta-pill">
                            <span>最新版本</span>
                            <strong>@_updateResult.LatestRelease.Version</strong>
                        </div>
                    }
                </div>

                <div class="update-modal-actions">
                    <button class="btn-primary" type="button" @onclick="CheckForUpdatesAsync" disabled="@_isCheckingForUpdate">
                        @(_isCheckingForUpdate ? "检查中..." : "检查更新")
                    </button>
                </div>

                @if (_updateResult is not null)
                {
                    if (!_updateResult.IsSuccess)
                    {
                        <div class="alert alert-warning">@_updateResult.ErrorMessage</div>
                    }
                    else if (_updateResult.IsUpdateAvailable && _updateResult.LatestRelease is not null)
                    {
                        <div class="update-result-card is-update">
                            <div class="update-result-head">
                                <div>
                                    <h3>发现新版本 @_updateResult.LatestRelease.Version</h3>
                                    <p>发布时间：@FormatPublishedAt(_updateResult.LatestRelease.PublishedAt)</p>
                                </div>
                                <a class="btn-small" href="@_updateResult.LatestRelease.HtmlUrl" target="_blank" rel="noopener noreferrer">查看 Release</a>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_updateResult.LatestRelease.Notes))
                            {
                                <p class="update-result-summary">@GetUpdateSummary(_updateResult.LatestRelease.Notes)</p>
                            }

                            <div class="update-result-actions">
                                <button class="btn-small" type="button" @onclick="DownloadUpdateAsync" disabled="@_isDownloadingUpdate">
                                    @(_isDownloadingUpdate ? "下载中..." : "下载并更新")
                                </button>
                            </div>

                            @if (_downloadResult is not null)
                            {
                                if (_downloadResult.IsSuccess && !string.IsNullOrWhiteSpace(_downloadResult.InstallerPath))
                                {
                                    <p class="update-download-path">已下载到：@_downloadResult.InstallerPath</p>
                                }
                                else if (!string.IsNullOrWhiteSpace(_downloadResult.ErrorMessage))
                                {
                                    <p class="update-download-path is-error">@_downloadResult.ErrorMessage</p>
                                }
                            }
                        </div>
                    }
                    else if (_updateResult.LatestRelease is not null)
                    {
                        @if (IsCurrentVersionAheadOfLatest(_updateResult))
                        {
                            <div class="alert alert-warning">当前版本（@_updateResult.CurrentVersion）高于更新源最新正式版（@_updateResult.LatestRelease.Version），请确认是否尚未发布该版本。</div>
                        }
                        else
                        {
                            <div class="alert alert-success">当前已是最新版本（@_updateResult.LatestRelease.Version）。</div>
                        }
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private IAutoStartService? _autoStartService;
    private bool _autoStart;
    private bool _isDark;
    private Action? _onAutoStartChanged;
    private bool _showUpdateModal;
    private AppUpdateCheckResult? _updateResult;
    private bool _isCheckingForUpdate;
    private AppUpdateDownloadResult? _downloadResult;
    private bool _isDownloadingUpdate;

    protected override void OnInitialized()
    {
        _autoStartService = ServiceProvider.GetService<IAutoStartService>();
        if (_autoStartService is not null)
        {
            _autoStart = _autoStartService.IsAutoStartEnabled();

            _onAutoStartChanged = () => InvokeAsync(() =>
            {
                _autoStart = _autoStartService.IsAutoStartEnabled();
                StateHasChanged();
            });
            _autoStartService.Changed += _onAutoStartChanged;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDark = await JS.InvokeAsync<bool>("minoTheme.isDark");
            StateHasChanged();
        }
    }

    private void ToggleAutoStart()
    {
        _autoStart = !_autoStart;
        _autoStartService?.SetAutoStart(_autoStart);
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("minoTheme.toggle", _isDark);
    }

    private void OpenUpdateModal()
    {
        _showUpdateModal = true;
    }

    private void CloseUpdateModal()
    {
        _showUpdateModal = false;
    }

    private async Task CheckForUpdatesAsync()
    {
        if (_isCheckingForUpdate)
            return;

        _isCheckingForUpdate = true;
        try
        {
            _updateResult = await AppUpdateService.CheckForUpdateAsync();
            _downloadResult = null;
        }
        catch (Exception ex)
        {
            _updateResult = AppUpdateCheckResult.Failed(AppVersionProvider.Version, $"检查更新失败：{ex.Message}");
            _downloadResult = null;
        }
        finally
        {
            _isCheckingForUpdate = false;
        }
    }

    private async Task DownloadUpdateAsync()
    {
        if (_isDownloadingUpdate || _updateResult?.LatestRelease is null)
            return;

        _isDownloadingUpdate = true;
        try
        {
            _downloadResult = await AppUpdatePackageService.DownloadInstallerAsync(_updateResult.LatestRelease);
            if (_downloadResult.IsSuccess && !string.IsNullOrWhiteSpace(_downloadResult.InstallerPath))
            {
                AppUpdatePackageService.LaunchInstallerAndShutdown(_downloadResult.InstallerPath);
            }
        }
        catch (Exception ex)
        {
            _downloadResult = AppUpdateDownloadResult.Failed($"下载更新失败：{ex.Message}");
        }
        finally
        {
            _isDownloadingUpdate = false;
        }
    }

    private static string FormatPublishedAt(DateTimeOffset? publishedAt) =>
        publishedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "未知";

    private static string GetUpdateSummary(string notes)
    {
        var normalized = notes.Replace("\r\n", "\n").Trim();
        if (string.IsNullOrWhiteSpace(normalized))
            return string.Empty;

        var lines = normalized
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(3);

        return string.Join(" / ", lines);
    }

    private static bool IsCurrentVersionAheadOfLatest(AppUpdateCheckResult result)
    {
        if (result.LatestRelease is null)
            return false;

        return CompareVersionText(result.CurrentVersion, result.LatestRelease.Version) > 0;
    }

    private static int CompareVersionText(string? left, string? right)
    {
        var hasLeft = GitHubReleaseUpdateResolver.TryParseVersion(left, out var leftVersion);
        var hasRight = GitHubReleaseUpdateResolver.TryParseVersion(right, out var rightVersion);

        if (!hasLeft && !hasRight)
            return 0;
        if (!hasLeft)
            return -1;
        if (!hasRight)
            return 1;

        return leftVersion.CompareTo(rightVersion);
    }

    public void Dispose()
    {
        if (_autoStartService is not null && _onAutoStartChanged is not null)
            _autoStartService.Changed -= _onAutoStartChanged;
    }
}

@page "/sessions"
@using MinoLink.Core
@using MinoLink.Core.Models
@inject Engine Engine
@inject SessionManager SessionManager
@implements IDisposable

<div class="page-header" style="margin-bottom:24px">
    <h1>会话<span class="hl">管理</span></h1>
    <p class="subtitle">按 Agent 原生会话分组展示，支持 Claude 与 Codex。</p>
</div>

<div class="sessions-active-bar">
    @{
        var _activeSessions = _activeSessionMap.Values.ToList();
    }
    @if (_activeSessions.Count > 0)
    {
        <div class="active-banner">
            <span class="active-banner-dot"></span>
            <span class="active-banner-label">正在活动的会话</span>
            @foreach (var r in _activeSessions)
            {
                <span class="active-banner-chip">@(r.FromName ?? r.From) &#8594; @GetAgentDisplay(r.AgentType) · @TrimPath(r.ProjectKey ?? "")</span>
            }
        </div>
    }
</div>
<div class="sessions-filter-bar">
    <button class="btn-small" @onclick="Refresh">↻ 刷新</button>
    <span class="filter-info">@_projects.Count 个目录 · @_projects.Sum(p => p.Sessions.Count) 个会话</span>
</div>

@if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">&#128193;</div>
        <p>暂无会话记录。</p>
    </div>
}
else
{
    <div class="sg-grid">
        @foreach (var project in _projects)
        {
            var activeRecord = _activeSessionMap.GetValueOrDefault(project.WorkDir);
            var isOpen = _expanded.Contains(project.WorkDir);
            var dirName = TrimPath(project.WorkDir).Split('/')[^1];
            var cardCls = "sg-card" + (activeRecord is not null ? " sg-card-live" : "");
            var arrowCls = "sg-arrow" + (isOpen ? " open" : "");
            <div class="@cardCls">
                <div class="sg-header" @onclick="() => ToggleGroup(project.WorkDir)">
                    <div class="sg-header-main">
                        <div class="sg-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg></div>
                        <div class="sg-path-wrap">
                            <div class="sg-dir">@dirName</div>
                            <div class="sg-fullpath">@TrimPath(project.WorkDir)</div>
                        </div>
                        @if (activeRecord is not null)
                        {
                            <span class="sg-live"><span class="sg-live-dot"></span>活跃</span>
                        }
                        <span class="@arrowCls">▶</span>
                    </div>
                    <div class="sg-meta-row">
                        <span class="sg-pill">@project.Sessions.Count 个会话</span>
                        <span class="sg-time">@project.LastActive.ToString("MM-dd HH:mm")</span>
                    </div>
                </div>
                @if (isOpen)
                {
                    <div class="sg-body">
                        @foreach (var s in project.Sessions)
                        {
                            var isActive = activeRecord?.AgentSessionId == s.SessionId;
                            <div class="@("sc" + (isActive ? " sc-active" : ""))">
                                <div class="sc-row1">
                                    <span class="sc-id">@s.SessionId[..8]</span>
                                    <span class="sc-time">@s.LastActive.ToString("MM-dd HH:mm")</span>
                                    @if (isActive) { <span class="sc-badge">&#9654; 当前</span> }
                                </div>
                                <div class="sc-summary">@(string.IsNullOrWhiteSpace(s.Summary) ? "—" : s.Summary)</div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<NativeProjectInfo> _projects = [];
    private Dictionary<string, SessionRecord> _activeSessionMap = [];
    private HashSet<string> _expanded = [];

    protected override void OnInitialized() => LoadData();

    private void LoadData()
    {
        var allProjects = new List<NativeProjectInfo>();
        allProjects.AddRange(ClaudeNativeSession.GetAllProjects());
        allProjects.AddRange(CodexNativeSession.GetAllProjects());

        _projects = allProjects
            .GroupBy(p => p.WorkDir, StringComparer.OrdinalIgnoreCase)
            .Select(g => new NativeProjectInfo(g.Key, g.First().EncodedDir, g.SelectMany(x => x.Sessions).OrderByDescending(x => x.LastActive).ToList()))
            .OrderByDescending(p => p.LastActive)
            .ToList();

        _activeSessionMap = Engine.GetActiveStatuses()
            .Select(status => SessionManager.GetActive(status.SessionKey))
            .Where(record => record?.ProjectKey is not null)
            .Cast<SessionRecord>()
            .GroupBy(record => record.ProjectKey!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(x => x.LastActiveAt).First(), StringComparer.OrdinalIgnoreCase);
    }

    private void Refresh() { LoadData(); StateHasChanged(); }

    private void ToggleGroup(string workDir)
    {
        if (!_expanded.Add(workDir)) _expanded.Remove(workDir);
    }

    private static string TrimPath(string path)
    {
        var parts = path.Replace("\\", "/").TrimEnd('/').Split('/');
        return parts.Length <= 2 ? path : "…/" + string.Join("/", parts[^2..]);
    }

    private static string GetAgentDisplay(string? agentType) => agentType switch
    {
        "codex" => "Codex",
        _ => "Claude",
    };

    public void Dispose() { }
}
